"""LangGraph agent: text-to-SQL with fast deterministic verify + optional revise."""

from __future__ import annotations

import json
import os
import re
from dataclasses import dataclass, field
from typing import Any

from langchain_openai import ChatOpenAI
from langgraph.graph import END, START, StateGraph

from agent import prompts
from agent.execution import ExecutionResult, execute_sql
from agent.context import render_context

MAX_ITERATIONS = int(os.environ.get("MAX_ITERATIONS", "2"))

VLLM_BASE_URL = os.environ.get("VLLM_BASE_URL", "http://localhost:8000/v1")
VLLM_MODEL = os.environ.get("VLLM_MODEL", "qwen3-sql")
LLM_API_KEY = os.environ.get("OPENAI_API_KEY", "dummy")
LLM_MAX_TOKENS = int(os.environ.get("LLM_MAX_TOKENS", "256"))


@dataclass
class AgentState:
    question: str
    db_id: str
    schema: str = ""
    sql: str = ""
    execution: ExecutionResult | None = None
    verify_ok: bool = False
    verify_issue: str = ""
    iteration: int = 0
    history: list[dict[str, Any]] = field(default_factory=list)


def llm() -> ChatOpenAI:
    return ChatOpenAI(
        model=VLLM_MODEL,
        base_url=VLLM_BASE_URL,
        api_key=LLM_API_KEY,
        temperature=0.0,
        max_tokens=LLM_MAX_TOKENS,
    )


def _attach_schema(state: AgentState) -> dict:
    return {"schema": render_context(state.db_id, state.question)}


def _extract_sql(text: str) -> str:
    fenced = re.search(r"```(?:sql)?\s*(.*?)```", str(text), re.DOTALL | re.IGNORECASE)
    sql = (fenced.group(1) if fenced else str(text)).strip()
    return sql.strip("`").strip()


def generate_sql_node(state: AgentState) -> dict:
    response = llm().invoke([
        ("system", prompts.GENERATE_SQL_SYSTEM),
        ("user", prompts.GENERATE_SQL_USER.format(
            schema=state.schema,
            question=state.question,
        )),
    ])
    sql = _extract_sql(response.content)
    return {
        "sql": sql,
        "iteration": state.iteration + 1,
        "history": state.history + [{"node": "generate_sql", "sql": sql}],
    }


def execute_node(state: AgentState) -> dict:
    return {"execution": execute_sql(state.db_id, state.sql)}


def verify_node(state: AgentState) -> dict:
    """
    Fast deterministic verifier.

    Avoids an LLM verifier. Sends to revise only for clear structural failures.
    """
    execution = state.execution
    q = state.question.lower()
    sql = state.sql.lower().strip()

    ok = True
    issue = ""

    ranking_words = ["top", "highest", "lowest", "largest", "smallest", "most", "least", "maximum", "minimum"]
    ranking_intent = any(w in q for w in ranking_words)

    average_intent = "average" in q or "mean" in q
    percentage_intent = "percentage" in q or "percent" in q

    count_intent = (
        "how many" in q
        or re.search(r"\bcount\b", q) is not None
        or (
            "number of" in q
            and not ranking_intent
            and not average_intent
            and "enrollment" not in q
        )
    )

    total_intent = any(
        phrase in q
        for phrase in [
            "total amount",
            "total number",
            "total spent",
            "total cost",
            "sum of",
        ]
    )

    list_or_attribute_intent = (
        not count_intent
        and not average_intent
        and not percentage_intent
        and not total_intent
        and any(
            w in q
            for w in [
                "list", "which", "what are", "what is", "mention", "provide",
                "name", "names", "id", "ids", "coordinate", "coordinates",
                "address", "location", "type", "reputation"
            ]
        )
    )

    if execution is None:
        ok = False
        issue = "No execution result."

    elif not execution.ok:
        ok = False
        issue = f"SQL execution error: {execution.error}"

    elif not sql.startswith(("select", "with")):
        ok = False
        issue = "SQL is not a read-only SELECT/WITH query."

    elif any(bad in f" {sql} " for bad in [" insert ", " update ", " delete ", " drop ", " alter ", " create "]):
        ok = False
        issue = "SQL contains a write/schema operation."

    elif count_intent and "count(" not in sql:
        ok = False
        issue = "Question asks for a count but SQL does not use COUNT."

    elif average_intent and "avg(" not in sql:
        ok = False
        issue = "Question asks for an average but SQL does not use AVG."

    elif total_intent and ("sum(" not in sql and "count(" not in sql):
        ok = False
        issue = "Question asks for a total/sum but SQL does not use SUM or COUNT."

    elif percentage_intent and "/" not in sql:
        ok = False
        issue = "Question asks for a percentage but SQL does not compute a ratio."

    elif ranking_intent and "order by" not in sql:
        ok = False
        issue = "Question asks for ranking but SQL has no ORDER BY."

    elif ranking_intent and any(w in q for w in ["top", "highest", "lowest", "largest", "smallest", "most", "least"]) and "limit" not in sql:
        ok = False
        issue = "Question asks for a ranked answer but SQL has no LIMIT."

    elif list_or_attribute_intent and "count(" in sql:
        ok = False
        issue = "Question asks for entities/details but SQL returns only a count."

    elif execution.row_count == 0 and "where" in sql:
        ok = False
        issue = "SQL returned zero rows with filters; filters may be wrong."

    else:
        rows = execution.rows or []
        if (
            list_or_attribute_intent
            and "join" in sql
            and "distinct" not in sql
            and len(rows) > 1
        ):
            unique_rows = {repr(row) for row in rows}
            if len(unique_rows) < len(rows):
                ok = False
                issue = "SQL returns duplicate rows from a JOIN; add DISTINCT for this list/attribute question."

    return {
        "verify_ok": ok,
        "verify_issue": issue,
        "history": state.history + [{
            "node": "verify",
            "mode": "deterministic",
            "ok": ok,
            "issue": issue,
            "row_count": execution.row_count if execution is not None and execution.ok else None,
        }],
    }

def revise_node(state: AgentState) -> dict:
    execution_text = state.execution.render(max_rows=10) if state.execution is not None else "No execution result"

    response = llm().invoke([
        ("system", prompts.REVISE_SYSTEM),
        ("user", prompts.REVISE_USER.format(
            schema=state.schema,
            question=state.question,
            sql=state.sql,
            execution=execution_text,
            issue=state.verify_issue,
        )),
    ])

    sql = _extract_sql(response.content)

    return {
        "sql": sql,
        "iteration": state.iteration + 1,
        "history": state.history + [{
            "node": "revise",
            "sql": sql,
            "issue": state.verify_issue,
        }],
    }


def route_after_verify(state: AgentState) -> str:
    if state.verify_ok:
        return "end"
    if state.iteration >= MAX_ITERATIONS:
        return "end"
    return "revise"


def build_graph():
    g = StateGraph(AgentState)

    g.add_node("attach_schema", _attach_schema)
    g.add_node("generate_sql", generate_sql_node)
    g.add_node("execute", execute_node)
    g.add_node("verify", verify_node)
    g.add_node("revise", revise_node)

    g.add_edge(START, "attach_schema")
    g.add_edge("attach_schema", "generate_sql")
    g.add_edge("generate_sql", "execute")
    g.add_edge("execute", "verify")
    g.add_conditional_edges(
        "verify",
        route_after_verify,
        {"revise": "revise", "end": END},
    )
    g.add_edge("revise", "execute")

    return g.compile()


graph = build_graph()
